{
  "tableName": "user_registrations_REALTIME",
  "tableType": "REALTIME",
  "schemaName": "user_registrations",
  "segmentsConfig": {
    "timeColumnName": "signupTimestamp",
    "timeType": "MILLISECONDS",
    "retentionTimeUnit": "DAYS",
    "retentionTimeValue": "7",
    "segmentPushType": "APPEND",
    "segmentAssignmentStrategy": "BalanceNumSegmentsSegmentAssignmentStrategy",
    "replication": "1",
    "replicasPerPartition": "1"
  },
  "tenants": {
    "broker": "DefaultTenant",
    "server": "DefaultTenant"
  },
  "tableIndexConfig": {
    "loadMode": "MMAP",
    "invertedIndexColumns": [
      "country",
      "accountType",
      "device"
    ],
    "bloomFilterColumns": [
      "userId"
    ],
    "rangeIndexColumns": [
      "age"
    ],
    "textIndexColumns": [
      "email"
    ],
    "noDictionaryColumns": [],
    "streamConfigs": {
      "streamType": "kafka",
      "stream.kafka.consumer.type": "lowlevel",
      "stream.kafka.topic.name": "user-registrations",
      "stream.kafka.bootstrap.servers": "kafka:9092",
      "stream.kafka.consumer.prop.auto.offset.reset": "smallest",
      "stream.kafka.consumer.factory.class.name": "org.apache.pinot.plugin.stream.kafka20.KafkaConsumerFactory",
      "stream.kafka.decoder.class.name": "org.apache.pinot.plugin.stream.kafka.KafkaJSONMessageDecoder",
      "realtime.segment.flush.threshold.rows": "10000",
      "realtime.segment.flush.threshold.time": "1h"
    },
    "starTreeIndexConfigs": [
      {
        "dimensionsSplitOrder": [
          "country",
          "accountType",
          "device"
        ],
        "skipStarNodeCreationForDimensions": [],
        "functionColumnPairs": [
          "SUM__registrationFee",
          "COUNT__userId"
        ],
        "maxLeafRecords": 10000
      }
    ]
  },
  "metadata": {
    "customConfigs": {}
  }
}
