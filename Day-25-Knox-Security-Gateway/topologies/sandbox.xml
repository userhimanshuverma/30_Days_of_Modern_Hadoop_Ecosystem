<topology>

    <gateway>
        <!-- 1. Authentication Provider (Apache Shiro integrating with LDAP) -->
        <provider>
            <role>authentication</role>
            <name>ShiroProvider</name>
            <enabled>true</enabled>
            <param>
                <name>sessionTimeout</name>
                <value>30</value>
            </param>
            <param>
                <name>main.ldapRealm</name>
                <value>org.apache.knox.gateway.shiro.realm.KnoxLdapRealm</value>
            </param>
            <!-- Connection to the OpenLDAP directory server -->
            <param>
                <name>main.ldapRealm.userDnTemplate</name>
                <value>uid={0},ou=people,dc=hadoop,dc=apache,dc=org</value>
            </param>
            <param>
                <name>main.ldapRealm.contextFactory.url</name>
                <value>ldap://ldap-service:389</value>
            </param>
            <param>
                <name>main.ldapRealm.contextFactory.authenticationMechanism</name>
                <value>simple</value>
            </param>
            <!-- Bind credentials for Knox to read LDAP directory -->
            <param>
                <name>main.ldapRealm.systemUsername</name>
                <value>cn=admin,dc=hadoop,dc=apache,dc=org</value>
            </param>
            <param>
                <name>main.ldapRealm.systemPassword</name>
                <value>adminpassword</value>
            </param>
            <!-- Group membership resolution settings -->
            <param>
                <name>main.ldapRealm.authorizationEnabled</name>
                <value>true</value>
            </param>
            <param>
                <name>main.ldapRealm.groupSearchBase</name>
                <value>ou=groups,dc=hadoop,dc=apache,dc=org</value>
            </param>
            <param>
                <name>main.ldapRealm.groupObjectClass</name>
                <value>groupOfNames</value>
            </param>
            <param>
                <name>main.ldapRealm.memberAttribute</name>
                <value>member</value>
            </param>
            <param>
                <name>urls./**</name>
                <value>authcBasic</value>
            </param>
        </provider>

        <!-- 2. Identity Assertion Provider (Passes verified username to backend services) -->
        <provider>
            <role>identity-assertion</role>
            <name>Default</name>
            <enabled>true</enabled>
        </provider>

        <!-- 3. Authorization Provider (AclsAuthz for access control policies) -->
        <provider>
            <role>authorization</role>
            <name>AclsAuthz</name>
            <enabled>true</enabled>
            <!-- Define access control lists: WebHDFS accessible only to groups admin and analyst -->
            <param>
                <name>WEBHDFS.acl</name>
                <value>*;admin,analyst;*</value>
            </param>
            <!-- Hive accessible only to specific groups -->
            <param>
                <name>HIVE.acl</name>
                <value>*;admin,analyst;*</value>
            </param>
        </provider>

        <!-- 4. HA Provider (Optional, for service discovery and failover) -->
        <provider>
            <role>ha</role>
            <name>HAProvider</name>
            <enabled>true</enabled>
            <param>
                <name>WEBHDFS</name>
                <value>maxFailoverAttempts=3;failoverSleep=1000;enabled=true</value>
            </param>
        </provider>
    </gateway>

    <!-- Services Exposed by Knox and mapped to Backend cluster nodes -->

    <!-- WebHDFS service (REST API for HDFS) -->
    <service>
        <role>WEBHDFS</role>
        <url>http://hadoop-namenode:9870/webhdfs</url>
    </service>

    <!-- Hive Server 2 JDBC over HTTP proxy service -->
    <service>
        <role>HIVE</role>
        <url>http://hive-server:10001/cliservice</url>
    </service>

    <!-- YARN ResourceManager UI and REST API -->
    <service>
        <role>RESOURCEMANAGER</role>
        <url>http://hadoop-namenode:8088/ws</url>
    </service>

</topology>
