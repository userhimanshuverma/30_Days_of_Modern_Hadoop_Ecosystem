          "refId": "A"
        },
        {
          "expr": "jvm_memory_bytes_used{job=\"hdfs-datanodes\", area=\"heap\"}",
          "legendFormat": "{{instance}} Heap Used",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          },
          "unit": "bytes"
        }
      }
