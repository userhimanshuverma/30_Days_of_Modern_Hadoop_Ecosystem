      "id": 5,
      "title": "HDFS Capacity Usage",
      "type": "timeseries",
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "hadoop_namenode_CapacityTotal",
          "legendFormat": "Capacity Total",
          "refId": "A"
        },
        {
          "expr": "hadoop_namenode_CapacityUsed",
          "legendFormat": "Capacity Used",
          "refId": "B"
        },
        {
          "expr": "hadoop_namenode_CapacityRemaining",
          "legendFormat": "Capacity Remaining",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth"
          },
          "unit": "bytes"
        }
