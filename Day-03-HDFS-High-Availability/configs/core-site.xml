<!-- core-site.xml -->
<configuration>
    <!-- Default filesystem URI: specifies the HA Logical Nameservice instead of a single NameNode host -->
    <property>
        <name>fs.defaultFS</name>
        <value>hdfs://mycluster</value>
        <description>The name of the default file system. In an HA setup, this points to the logical nameservice ID configured in hdfs-site.xml.</description>
    </property>

    <!-- Temp Directory: Local directory path used as a base for temporary storage -->
    <property>
        <name>hadoop.tmp.dir</name>
        <value>/tmp/hadoop-${user.name}</value>
        <description>A base for other temporary directories.</description>
    </property>

    <!-- ZooKeeper Quorum: Address of ZooKeeper instances used for automatic failover coordination -->
    <property>
        <name>ha.zookeeper.quorum</name>
        <value>zookeeper:2181</value>
        <description>A list of ZooKeeper servers used by ZKFC for leader election and failover synchronization.</description>
    </property>

    <!-- Buffer Size: The size of buffer for write/read sequence files -->
    <property>
        <name>io.file.buffer.size</name>
        <value>131072</value>
        <description>The size of buffer for use in sequence files. Formatted as 128KB for optimized disk I/O in production.</description>
    </property>
</configuration>
