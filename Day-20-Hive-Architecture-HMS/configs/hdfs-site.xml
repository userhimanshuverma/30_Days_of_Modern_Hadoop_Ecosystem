<configuration>
  <property>
    <name>dfs.replication</name>
    <value>1</value>
    <description>Default replication count for development cluster</description>
  </property>

  <property>
    <name>dfs.permissions.enabled</name>
    <value>false</value>
    <description>Disable HDFS permissions checks to avoid user mismatches during testing</description>
  </property>

  <property>
    <name>dfs.namenode.name.dir</name>
    <value>file:///hadoop/dfs/name</value>
    <description>Local filesystem path for NameNode storage</description>
  </property>

  <property>
    <name>dfs.datanode.data.dir</name>
    <value>file:///hadoop/dfs/data</value>
    <description>Local filesystem path for DataNode storage</description>
  </property>

  <property>
    <name>dfs.namenode.rpc-address</name>
    <value>namenode:9000</value>
    <description>RPC host and port configuration</description>
  </property>
</configuration>
