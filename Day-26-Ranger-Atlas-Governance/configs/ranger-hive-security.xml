<configuration>
    <!-- Ranger Service Name matching the defined service in Ranger Admin Console -->
    <property>
        <name>ranger.plugin.hive.service.name</name>
        <value>production_hive</value>
    </property>

    <!-- Ranger Admin REST URL -->
    <property>
        <name>ranger.plugin.hive.policy.rest.url</name>
        <value>http://ranger-admin:6080</value>
    </property>

    <!-- Polling interval for downloading policy changes -->
    <property>
        <name>ranger.plugin.hive.policy.pollIntervalMs</name>
        <value>30000</value>
    </property>

    <!-- Local policy cache directory to survive Ranger Admin downtime -->
    <property>
        <name>ranger.plugin.hive.policy.cache.dir</name>
        <value>/etc/ranger/production_hive/policycache</value>
    </property>

    <!-- Implementation class for policy source -->
    <property>
        <name>ranger.plugin.hive.policy.source.impl</name>
        <value>org.apache.ranger.admin.client.RangerAdminRESTClient</value>
    </property>

    <!-- Enable Access Auditing -->
    <property>
        <name>xasecure.audit.is.enabled</name>
        <value>true</value>
    </property>

    <!-- Destination for Ranger Hive Audits (Solr Cloud) -->
    <property>
        <name>xasecure.audit.destination.solr</name>
        <value>true</value>
    </property>
    <property>
        <name>xasecure.audit.destination.solr.urls</name>
        <value>http://solr:8983/solr/ranger_audits</value>
    </property>
</configuration>
