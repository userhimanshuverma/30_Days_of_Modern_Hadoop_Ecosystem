graph TD
    subgraph Range Assignment Strategy
        P0[T1-P0] --> C1A[Consumer 1]
        P1[T1-P1] --> C1A
        P2[T1-P2] --> C2A[Consumer 2]
        P3[T2-P0] --> C1A
        P4[T2-P1] --> C1A
        P5[T2-P2] --> C2A
    end

    subgraph Round Robin Assignment Strategy
        R0[T1-P0] --> CR1[Consumer 1]
        R1[T1-P1] --> CR2[Consumer 2]
        R2[T1-P2] --> CR1
        R3[T2-P0] --> CR2
        R4[T2-P1] --> CR1
        R5[T2-P2] --> CR2
    end

    subgraph Sticky Assignment Strategy
        S0[T1-P0] --> CS1[Consumer 1]
        S1[T1-P1] --> CS1
        S2[T1-P2] --> CS2[Consumer 2]
        
        style CS1 fill:#9f9,stroke:#333
        style CS2 fill:#f9f,stroke:#333
    end
